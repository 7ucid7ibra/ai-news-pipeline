# Required for LLM ranking (Phase 3)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Reddit API (falls back to public scraping without these)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-news-automation/0.1

# Optional: Product Hunt API
PH_ACCESS_TOKEN=

# Optional: Telegram voice memos
TELEGRAM_BOT_TOKEN=
# Get this by messaging @BotFather on Telegram and creating a bot

# Optional: ElevenLabs text-to-speech
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Free API key at https://elevenlabs.io/
# Find voice IDs at https://elevenlabs.io/voice-lab
